# Prometheus environment template
# Most users only need to review these values after `./setup.sh` creates `.env.local`.
# The usual edits are: engine path, vault path, and any cloud API keys.

# Required local paths
PROMETHEUS_ENGINE=~/dev/Prometheus
PROMETHEUS_VAULT=~/vault

# Setup/bootstrap mode. setup.sh persists the resolved mode into .env.local.
# Supported values: full-local, hybrid-local, remote-infra, minimal.
PROMETHEUS_RUNTIME_MODE=full-local

# Optional: point setup.sh at a remote Docker/Ollama host before running it.
# setup.sh writes the matching service URLs into `.env.local` automatically.
# PROMETHEUS_INFRA_HOST=192.168.x.x

# Optional cloud provider key for routed Anthropic calls
ANTHROPIC_API_KEY=your-anthropic-api-key

# Core service defaults
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379
LANGFUSE_HOST=http://localhost:3000
PROMETHEUS_OLLAMA_LOCAL_HOST=http://127.0.0.1:11434
PROMETHEUS_OLLAMA_REMOTE_HOST=

# Langfuse / local infra secrets
LANGFUSE_NEXTAUTH_SECRET=change-me
LANGFUSE_SALT=change-me
POSTGRES_USER=prometheus
POSTGRES_PASSWORD=change-me
POSTGRES_DB=langfuse
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# Runtime defaults
PROMETHEUS_RTK_MAX_TOKENS=450
PROMETHEUS_CAVEMAN_MODEL=phi3:mini
PROMETHEUS_DAILY_BUDGET=5.0
PROMETHEUS_OPUS_BUDGET=2.0
PROMETHEUS_MAX_PRE_SEND_TOKENS=8000
PROMETHEUS_PROVIDER_ANTHROPIC=1
PROMETHEUS_PROVIDER_OPENROUTER=1
PROMETHEUS_PROVIDER_OLLAMA=1
PROMETHEUS_CLASSIFIER_CLOUD_MODEL=claude-haiku-4-5-20251001
PROMETHEUS_CLASSIFIER_TIMEOUT=4.0
PROMETHEUS_POLICY_VERSION=2026-04-21

# Expansion
PROMETHEUS_EXPANSION_SOURCE_CATALOG=${PROMETHEUS_ENGINE}/config/expansion_sources.json
PROMETHEUS_EXPANSION_ENABLED=true
PROMETHEUS_EXPANSION_MANUAL_ONLY=true
PROMETHEUS_EXPANSION_CONTEXTS=knowledge,career,personal
PROMETHEUS_EXPANSION_ALLOW_CLOUD=true
PROMETHEUS_EXPANSION_MONTHLY_BUDGET=4.0
PROMETHEUS_EXPANSION_SOFT_CAP=3.2
PROMETHEUS_EXPANSION_HARD_CAP=4.0

# Platform-generated defaults that setup.sh refreshes
PROMETHEUS_PLATFORM=mac
EMBEDDING_PROVIDERS=CoreMLExecutionProvider,CPUExecutionProvider
OLLAMA_FLASH=false
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_MODEL_PRIMARY=gemma4:e4b
OLLAMA_MODEL_KNOWLEDGE=gemma4:e4b
OLLAMA_KEEP_ALIVE=10m
OLLAMA_NUM_PARALLEL=2
OLLAMA_HOST=http://localhost:11434

# Compatibility / local defaults
QDRANT_HOST=localhost
QDRANT_PORT=6333
REDIS_HOST=localhost
REDIS_PORT=6379
PROMETHEUS_VECTOR_SIZE=384
PROMETHEUS_WORK_CTX=0
SQLITE_PATH=./data/prometheus.db
