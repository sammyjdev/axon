# Prometheus Engine — configurações de ambiente
# Copie para .env.local e ajuste conforme sua máquina.
#
# Este arquivo é documental e seguro para onboarding:
# - prioriza os nomes canônicos lidos pelo runtime atual
# - mantém algumas variáveis legadas ainda usadas por módulos específicos

# Paths canônicos
PROMETHEUS_VAULT=~/vault
PROMETHEUS_ENGINE=/Users/samdev/dev/Prometheus

# Runtime principal
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379
PROMETHEUS_OLLAMA_LOCAL_HOST=http://127.0.0.1:11434
# Para Mac usando infra no desktop, substitua localhost pelo host remoto:
# PROMETHEUS_DESKTOP_HOST=192.168.68.104
# QDRANT_URL=http://192.168.68.104:6333
# REDIS_URL=redis://192.168.68.104:6379
# PROMETHEUS_OLLAMA_LOCAL_HOST=http://192.168.68.104:11434
PROMETHEUS_RTK_MAX_TOKENS=450
# Modelo usado pelo caveman compressor (semântico). Fallback: OLLAMA_MODEL_PRIMARY.
# Use qualquer modelo local do Ollama nativo — não requer Docker.
PROMETHEUS_CAVEMAN_MODEL=qwen2.5-claude

# Router / cloud budget
PROMETHEUS_DAILY_BUDGET=5.0
PROMETHEUS_OPUS_BUDGET=2.0
PROMETHEUS_MAX_PRE_SEND_TOKENS=8000

# Providers
PROMETHEUS_PROVIDER_ANTHROPIC=1
PROMETHEUS_PROVIDER_OPENROUTER=1
PROMETHEUS_PROVIDER_OLLAMA=1
PROMETHEUS_CLASSIFIER_CLOUD_MODEL=claude-haiku-4-5-20251001
PROMETHEUS_CLASSIFIER_TIMEOUT=4.0
PROMETHEUS_POLICY_VERSION=2026-04-21

# LiteLLM / Anthropic
ANTHROPIC_API_KEY=

# Langfuse
LANGFUSE_HOST=http://localhost:3000

# Postgres / Langfuse
POSTGRES_USER=prometheus
POSTGRES_PASSWORD=local
POSTGRES_DB=langfuse

# Expansion
PROMETHEUS_EXPANSION_SOURCE_CATALOG=/Users/samdev/dev/Prometheus/config/expansion_sources.json
PROMETHEUS_EXPANSION_ENABLED=true
PROMETHEUS_EXPANSION_MANUAL_ONLY=true
PROMETHEUS_EXPANSION_CONTEXTS=knowledge,career,personal
PROMETHEUS_EXPANSION_ALLOW_CLOUD=true
PROMETHEUS_EXPANSION_MONTHLY_BUDGET=4.0
PROMETHEUS_EXPANSION_SOFT_CAP=3.2
PROMETHEUS_EXPANSION_HARD_CAP=4.0

# Platform-generated vars usadas por setup.sh / docker / Ollama
PROMETHEUS_PLATFORM=mac
EMBEDDING_PROVIDERS=CoreMLExecutionProvider,CPUExecutionProvider
OLLAMA_FLASH=false
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_MODEL_PRIMARY=gemma4:e4b
OLLAMA_MODEL_KNOWLEDGE=gemma4:e4b
OLLAMA_KEEP_ALIVE=10m
OLLAMA_NUM_PARALLEL=2

# Compatibilidade com módulos legados / auxiliares.
# QDRANT_URL é canônico; QDRANT_HOST/QDRANT_PORT ficam como fallback legado.
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Redis guarda exclusivamente o grafo de dependências de código.
REDIS_HOST=localhost
REDIS_PORT=6379
OLLAMA_HOST=http://localhost:11434
# Neo4j é exclusivo do Mem0. Use bolt://192.168.68.104:7687 no Mac quando a infra rodar no desktop.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=local-password
PROMETHEUS_VECTOR_SIZE=384
PROMETHEUS_WORK_CTX=0

# SQLite path
SQLITE_PATH=./data/prometheus.db
