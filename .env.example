# Prometheus Engine — configurações de ambiente
# Copie para .env.local e ajuste conforme sua máquina

# Gerado automaticamente por src/config/platform.py
PROMETHEUS_VAULT=~/vault
PROMETHEUS_ENGINE=/Users/samdev/dev/Prometheus

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Postgres / Langfuse
POSTGRES_USER=prometheus
POSTGRES_PASSWORD=local
POSTGRES_DB=langfuse
LANGFUSE_HOST=http://localhost:3000

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_KEEP_ALIVE=-1
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=1

# LiteLLM / Anthropic (coloque sua chave)
ANTHROPIC_API_KEY=

# Budget diário de tokens (USD)
DAILY_BUDGET_USD=0.10
OPUS_BUDGET_USD=0.05

# SQLite path
SQLITE_PATH=./data/prometheus.db
