<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.axon.mirror</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>REPLACE_WITH/scripts/axon-mirror.sh</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>AXON_PG_URL</key><string>postgresql://axon:axon@localhost:5433/axon</string>
    <key>AXON_MIRROR_PG_URL</key><string>REPLACE_WITH_NEON_URL</string>
  </dict>
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>20</integer><key>Minute</key><integer>0</integer></dict>
  <key>StandardErrorPath</key><string>/tmp/axon-mirror.err</string>
  <key>StandardOutPath</key><string>/tmp/axon-mirror.out</string>
</dict>
</plist>
